{
	"Create React Component": {
		"prefix": "rc",
		"body": [
			"import React from 'react';",
			"import './styles.css';",
			"",
			"const ${1:functionName} = (props) => {",
			"	return(",
			"		<div>",
			"			$0",
			"		</div>",
			"	);",
			"}",
			"",
			"export default ${1:functionName};",
            "",
		]
	},

	"Create React native Component": {
		"prefix": "rnc",
		"body": [
			"import React from 'react';",
			"import {StyleSheet, Text, View} from 'react-native';",
			"",
			"const ${1:functionName} = (props) => {",
			"	return(",
			"		<View>",
			"			$0",
			"		</View>",
			"	);",
			"}",
			"",
			"const styles = StyleSheet.create({",
			"	",
			"});",
			"",
			"export default ${1:functionName};",
            "",
		]
	},

	"useEffect": {
		"prefix": "ue",
		"body": [
			"useEffect(() => {",
			"	$0",
			"}, [$1]);",
			"",
		]	
	},

	"useState": {
		"prefix": "us",
		"body": "const [${1:variable}, set${2}${1:variable}] = useState(${3});"
	},

	"console.log": {
		"prefix": "conlog",
		"body": "console.log($0);"
	},

	"arrow function": {
		"prefix": "arrow",
		"body": [
			"const $1 = ($2) => {",
			"	$0",
			"};"
		]
	},

	"anonymous function": {
		"prefix": "anonymous function",
		"body": "($1) => { $0 }",
	},

	"event.target.value": {
		"prefix": "etv",
		"body": "event.target.value",
	},

	"console log aqui": {
		"prefix": "aqui",
		"body": "console.log('aqui');"
	},

	"Text": {
		"prefix": "text",
		"body": "<Text>$0</Text>"
	},
	
	"View": {
		"prefix": "view",
		"body": "<View>$0</View>"
	},

	"style": {
		"prefix": "style",
		"body": "style={styles.$0}"
	},

	"configure style": {
		"prefix": "nss",
		"body": [
			"${1:styleName}: {",
			"	$0",
			"},",
		]
	}
}
